<% d = section.data %>
<section class="s" id="<%= d.id %>">
  <div class="wrap">
    <div class="s-head">
      <div class="s-num"><%= d.num %></div>
      <h2 class="s-title"><%= d.title %></h2>
      <div class="s-sub"><%= d.subtitle %></div>
    </div>

    <div class="surface">
      <% d.rows.each do |r| %>
        <div class="surface-row">
          <div class="surface-desc">
            <h5><%= r.heading %></h5>
            <p><%= r.body %></p>
          </div>
          <div class="surface-code">
<pre class="code"><%= r.code_html.chomp.html_safe %></pre>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
